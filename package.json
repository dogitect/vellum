{
  "name": "vellum",
  "version": "2.0.0",
  "description": "Vellum by Dogitect — Crafting clarity on stage.",
  "author": "Leon Xia",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "upload-to-r2": "bun run scripts/upload-to-r2.ts",
    "validate-content": "bun run scripts/validate-content.ts",
    "start": "ng serve --open",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "build:watch": "ng build --configuration development --watch",
    "test": "ng test",
    "deploy": "bun run build && wrangler deploy",
    "deploy:staging": "bun run build && wrangler deploy --env staging",
    "preview": "bun run build && wrangler dev",
    "cf:tail": "wrangler tail",
    "cf:types": "wrangler types",
    "lint": "eslint src/**/*.ts src/**/*.html",
    "lint:fix": "eslint src/**/*.ts src/**/*.html --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\""
  },
  "private": true,
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@webgpu/types": "^0.1.69",
    "bun-types": "^1.3.11",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
